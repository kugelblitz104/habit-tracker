# Database Configuration
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/habit_tracker
SQLALCHEMY_ECHO=false

# JWT Security Configuration
# CRITICAL: Generate a strong secret key with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server Configuration
HOST=0.0.0.0
PORT=8080

# JWT Token Expiration
ACCESS_TOKEN_EXPIRY_MINUTES=30
REFRESH_TOKEN_EXPIRY_DAYS=7
RESET_TOKEN_EXPIRY_MINUTES=30

# Algorithm
ALGORITHM=HS256

# Password-reset email (provider-agnostic SMTP). Leave SMTP_HOST blank in local
# dev — the reset link is logged to the server console instead of emailed.
# Example (Resend): host smtp.resend.com, user "resend", password = API key.
# SendGrid / Mailgun / SES all expose SMTP too — only these vars change.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Habit Tracker <noreply@yourdomain.com>

# Where the emailed reset link points (the frontend reset page). The final URL
# is ${RESET_URL_BASE}?token=... — set this to your deployed frontend in prod.
RESET_URL_BASE=http://localhost:3000/reset-password
